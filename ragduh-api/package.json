{
  "name": "ragduh-api",
  "version": "1.0.0",
  "description": "RAG ingestion API for Cloudflare Workers",
  "main": "dist/index.js",
  "scripts": {
    "proxy": "node scripts/proxy-server.mjs",
    "dev": "wrangler dev",
    "dev:e2e": "wrangler dev --config wrangler.e2e.toml",
    "deploy": "wrangler deploy",
    "e2e:deploy": "wrangler deploy --config wrangler.e2e.toml",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run src/__tests__/e2e/index.test.ts",
    "e2e:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/e2e-setup.ps1",
    "e2e:setup:sh": "bash ./scripts/e2e-setup.sh",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "keywords": [
    "rag",
    "chunking",
    "embedding",
    "cloudflare"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/azure": "^2.0.30",
    "@ai-sdk/google": "^2.0.14",
    "@ai-sdk/openai": "^2.0.30",
    "@ai-sdk/provider-utils": "^4.0.19",
    "@langchain/textsplitters": "^1.0.1",
    "ai": "^6.0.116",
    "ai-gateway-provider": "^3.1.1",
    "hono": "^4.12.8",
    "https-proxy-agent": "^8.0.0",
    "node-fetch": "^3.3.2",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250408.0",
    "@types/node": "^22.13.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}